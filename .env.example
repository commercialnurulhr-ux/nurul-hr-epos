# NURUL HR EPOS - Environment Configuration

# Application
NODE_ENV=development
PORT=3000
FRONTEND_PORT=3001
APP_NAME=NURUL HR EPOS
COMPANY_NAME=NURUL HR SDN BHD
COMPANY_REGISTRATION=BD123456
CURRENCY=BND
COUNTRY=BN

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nurul_hr_epos
DB_USER=epos_user
DB_PASSWORD=secure_password
DB_SSL=false

# Offline Database
OFFLINE_DB_PATH=./data/epos.db

# Sync Configuration
SYNC_INTERVAL=300000
SYNC_RETRY_ATTEMPTS=3
SYNC_TIMEOUT=30000

# Authentication
JWT_SECRET=change_this_in_production
JWT_EXPIRE=24h

# Printer
PRINTER_ENABLED=true
PRINTER_MODEL=thermal_80mm

# Banking
BIBD_ACCOUNT_NAME=NURUL HR SDN BHD
BIBD_ACCOUNT_NUMBER=1234567890

# Stock Management
DEFAULT_LOW_STOCK_LEVEL=10
EXPIRY_WARNING_DAYS=7

# Backup
AUTO_BACKUP_ENABLED=true
BACKUP_INTERVAL=86400000

# Migration
MIGRATION_ENABLED=true
MIGRATION_BATCH_SIZE=1000

# Logging
LOG_LEVEL=info